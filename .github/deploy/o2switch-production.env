# Paramètres non sensibles du déploiement de production.
# Les identifiants sont configurés dans les secrets GitHub Actions ; voir README.md.

ALLOWED_ACTOR="mattrbdr"
DEPLOY_BRANCH="main"
NODE_VERSION="22"

INSTALL_COMMAND="npm ci"
CHECK_COMMANDS="npm run typecheck"
BUILD_COMMAND="npm run build"
BUILD_OUTPUT="build"

# Chemins relatifs au répertoire personnel O2Switch/cPanel.
REMOTE_PATH="docs.racinesapp.com/"
BACKUP_PATH="backups/racines-documentation/"
KEEP_BACKUPS="5"
